# ==============================================================
# Variáveis de ambiente — Copie este arquivo para .env e preencha
# NÃO commite o .env com valores reais!
# ==============================================================

# Supabase — encontre no painel: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_PROJECT_ID="seu-project-id-aqui"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
SUPABASE_URL="https://seu-project-id-aqui.supabase.co"

# Estas são expostas ao frontend (prefixo VITE_)
VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
VITE_SUPABASE_URL="https://seu-project-id-aqui.supabase.co"

# Apenas para funções server-side (NÃO expor ao frontend)
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-aqui"
